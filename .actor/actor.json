{
    "actorSpecification": 1,
    "name": "empresite-scraper",
    "title": "Empresite Spain Business Scraper",
    "description": "Scrapes Spanish business directory empresite.eleconomista.es by keyword across all provinces",
    "version": "1.0.0",
    "input": "./input_schema.json",
    "dockerfile": "../Dockerfile",
    "minMemoryMbytes": 2048,
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "Empresite Results",
            "views": {
                "companies": {
                    "title": "Companies",
                    "transformation": {
                        "fields": [
                            "keyword",
                            "provincia",
                            "city",
                            "name",
                            "description",
                            "address",
                            "profileUrl",
                            "phone",
                            "email",
                            "website",
                            "page",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "keyword": { "label": "Keyword", "format": "text" },
                            "provincia": { "label": "Province", "format": "text" },
                            "city": { "label": "City", "format": "text" },
                            "name": { "label": "Company Name", "format": "text" },
                            "description": { "label": "Description", "format": "text" },
                            "address": { "label": "Address", "format": "text" },
                            "profileUrl": { "label": "Profile URL", "format": "link" },
                            "phone": { "label": "Phone", "format": "text" },
                            "email": { "label": "Email", "format": "text" },
                            "website": { "label": "Website", "format": "link" },
                            "page": { "label": "Page", "format": "number" },
                            "scrapedAt": { "label": "Scraped At", "format": "text" }
                        }
                    }
                }
            }
        }
    }
}
